# ── LLM Providers ──────────────────────────────────────────
# Add API keys for the providers you want to use.
# You can switch between them from the main menu.

# Groq (RECOMMENDED for speed - fastest inference)
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# ZhipuAI (GLM models - slower but good reasoning)
ZHIPU_API_KEY=your-zhipu-key
ZHIPU_MODEL=glm-4.7-flash

# Context7 (for documentation retrieval)
CONTEXT7_API_KEY=your-context7-key

# Tavily (web search for prompt enhancement)
TAVILY_API_KEY=your-tavily-key

# Workspace — where agent creates project files
WORKSPACE=/workspace